# =============================================================================
# IOL (Invertir Online) — credenciales de la cuenta de broker
# Documentación: scripts/IOL_API.md
# =============================================================================
IOL_USERNAME=
IOL_PASSWORD=

# =============================================================================
# Supabase — base de datos + realtime
# Crear proyecto en supabase.com → Settings → API
# =============================================================================
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # solo para el script de snapshot (server-side)

# =============================================================================
# Configuración del snapshot
# =============================================================================
SNAPSHOT_UNDERLYING=GGAL       # subyacente a capturar
SNAPSHOT_RATE=0.35             # tasa libre de riesgo anualizada (ej. 0.35 = 35%)

# =============================================================================
# Next.js (prefijo NEXT_PUBLIC_ para variables accesibles en el browser)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
